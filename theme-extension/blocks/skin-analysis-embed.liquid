{% comment %}
  AI Skin Analysis - App Embed
  Floating widget for skin analysis with AI
{% endcomment %}

{% liquid
  assign api_url = 'https://aiskinanalysis.onrender.com'
  assign shop_domain = shop.permanent_domain
%}

{{ 'skin-analysis-embed.css' | asset_url | stylesheet_tag }}

<div id="ai-skin-analysis-widget" 
     data-api-url="{{ api_url }}"
     data-shop="{{ shop_domain }}"
     style="display:none;">
  
  <!-- Floating Trigger Button -->
  <button type="button" id="skin-analysis-trigger" class="skin-trigger-btn">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="8" r="5"/>
      <path d="M20 21a8 8 0 1 0-16 0"/>
    </svg>
    <span>Skin Analysis</span>
  </button>

  <!-- Modal -->
  <div id="skin-analysis-modal" class="skin-modal">
    <div class="skin-modal-content">
      <button type="button" class="skin-close-btn" id="skin-close-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      
      <div class="skin-header">
        <h2>AI Skin Analysis</h2>
        <p>Get personalized skincare recommendations</p>
      </div>

      <!-- Camera Section -->
      <div id="skin-camera-section" class="skin-camera-section">
        <div class="skin-camera-frame">
          <video id="skin-video" autoplay playsinline muted></video>
          <canvas id="skin-canvas" style="display:none;"></canvas>
          <div id="skin-placeholder" class="skin-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
              <circle cx="12" cy="13" r="4"/>
            </svg>
            <p>Position your face in the frame</p>
          </div>
          <div id="skin-face-guide" class="skin-face-guide"></div>
          <div id="skin-scan-overlay" class="skin-scan-overlay">
            <div class="skin-scan-line"></div>
          </div>
        </div>

        <div class="skin-buttons">
          <button type="button" id="skin-start-btn" class="skin-btn skin-btn-primary">
            Start Camera
          </button>
          <button type="button" id="skin-capture-btn" class="skin-btn skin-btn-primary" style="display:none;">
            Analyze My Skin
          </button>
        </div>
      </div>

      <!-- Loading Section -->
      <div id="skin-loading-section" class="skin-loading-section" style="display:none;">
        <div class="skin-spinner"></div>
        <p>Analyzing your skin...</p>
      </div>

      <!-- Results Section -->
      <div id="skin-results-section" class="skin-results-section" style="display:none;">
        <div class="skin-score">
          <span id="skin-score-value" class="score-value">--</span>
          <span class="score-label">Skin Score</span>
        </div>
        
        <div class="skin-details">
          <div class="skin-detail-card">
            <h4>Skin Type</h4>
            <p id="skin-type-value">-</p>
          </div>
          <div class="skin-detail-card">
            <h4>Concerns</h4>
            <div id="skin-concerns-tags" class="concerns-tags"></div>
          </div>
        </div>

        <div id="skin-routine" class="skin-routine">
          <h4>Recommended Routine</h4>
          <div id="skin-routine-steps" class="routine-steps"></div>
        </div>

        <div id="skin-products-section" class="skin-products" style="display:none;">
          <h4>Recommended Products</h4>
          <div id="skin-products-grid" class="products-grid"></div>
        </div>

        <button type="button" id="skin-retry-btn" class="skin-btn skin-btn-secondary">
          Try Again
        </button>
      </div>

      <div class="skin-disclaimer">
        <p>For cosmetic purposes only. No images stored.</p>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'skin-analysis-embed.js' | asset_url }}" defer></script>

<script>
  // Initialize widget after DOM ready
  document.addEventListener('DOMContentLoaded', function() {
    var widget = document.getElementById('ai-skin-analysis-widget');
    if (widget) {
      widget.style.display = 'block';
      console.log('[AI Skin Analysis] Widget initialized');
    }
  });
</script>

{% schema %}
{
  "name": "AI Skin Analysis",
  "target": "body",
  "settings": []
}
{% endschema %}

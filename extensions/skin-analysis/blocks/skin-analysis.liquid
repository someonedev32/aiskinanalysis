{% comment %}
  AI Skin Analysis - Theme App Extension Block
  A professional skin analysis widget powered by AI
  
  For Online Store 2.0 themes - Add this block to any section
{% endcomment %}

{% schema %}
{
  "name": "AI Skin Analysis",
  "target": "section",
  "stylesheet": "skin-analysis.css",
  "javascript": "skin-analysis.js",
  "templates": ["page", "index", "product", "collection", "article"],
  "settings": [
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AI Skin Analysis"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover your perfect skincare routine. Our AI analyzes your skin in seconds and provides personalized recommendations."
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Primary Color",
      "default": "#2D5A4A"
    },
    {
      "type": "header",
      "content": "Product Recommendations"
    },
    {
      "type": "collection",
      "id": "product_collection",
      "label": "Product Collection",
      "info": "Select a collection of skincare products to recommend based on analysis results"
    },
    {
      "type": "header",
      "content": "Additional Options"
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show Disclaimer",
      "default": true,
      "info": "Display privacy and medical disclaimer at the bottom"
    }
  ]
}
{% endschema %}

{% liquid
  assign primary_color = block.settings.brand_color | default: '#2D5A4A'
  assign collection_id = ''
  if block.settings.product_collection
    assign collection_id = block.settings.product_collection.id
  endif
%}

<style>
  #skin-analysis-{{ block.id }} {
    --skin-primary: {{ primary_color }};
  }
  
  #skin-analysis-{{ block.id }} .lumina-btn-primary,
  #skin-analysis-{{ block.id }} button.lumina-btn-primary {
    background: {{ primary_color }};
    color: #fff;
  }
  
  #skin-analysis-{{ block.id }} .lumina-btn-primary:hover,
  #skin-analysis-{{ block.id }} button.lumina-btn-primary:hover {
    opacity: 0.9;
  }
  
  #skin-analysis-{{ block.id }} .lumina-score-value { 
    color: {{ primary_color }}; 
  }
  
  #skin-analysis-{{ block.id }} .lumina-badge { 
    background: {{ primary_color }}; 
    color: #fff; 
  }
  
  #skin-analysis-{{ block.id }} .lumina-card-icon { 
    background: {{ primary_color }}; 
  }
  
  #skin-analysis-{{ block.id }} .lumina-step-num { 
    background: {{ primary_color }}; 
  }
  
  #skin-analysis-{{ block.id }} .lumina-spinner { 
    border-top-color: {{ primary_color }}; 
  }
  
  #skin-analysis-{{ block.id }} .lumina-title {
    color: {{ primary_color }};
  }
  
  #skin-analysis-{{ block.id }} .lumina-scan-line {
    background: linear-gradient(90deg, transparent 0%, {{ primary_color }} 50%, transparent 100%);
    box-shadow: 0 0 20px {{ primary_color }};
  }
  
  #skin-analysis-{{ block.id }} .lumina-face-guide {
    border-color: {{ primary_color }};
    opacity: 0.5;
  }
  
  #skin-analysis-{{ block.id }} .lumina-camera-frame.active {
    border-color: {{ primary_color }};
  }
  
  #skin-analysis-{{ block.id }} .lumina-product-card:hover {
    border-color: {{ primary_color }};
  }
  
  #skin-analysis-{{ block.id }} .lumina-tag:hover {
    border-color: {{ primary_color }};
    color: {{ primary_color }};
  }
</style>

<div id="skin-analysis-{{ block.id }}"
     class="lumina-wrapper"
     data-block-id="{{ block.id }}"
     data-app-proxy-url="{{ shop.url }}/apps/skin-analysis"
     data-shop="{{ shop.permanent_domain }}"
     data-collection-id="{{ collection_id }}">

  <header class="lumina-header">
    <h2 class="lumina-title">{{ block.settings.heading | escape }}</h2>
    <p class="lumina-subtitle">{{ block.settings.subheading | escape }}</p>
  </header>

  <section class="lumina-camera-section" data-camera-section>
    <div class="lumina-camera-frame" data-camera-frame>
      <video autoplay playsinline muted class="lumina-video" data-video></video>
      <canvas style="display:none;" data-canvas></canvas>
      <div class="lumina-face-guide" style="display:none;" data-face-guide></div>
      <div class="lumina-scan-overlay" style="display:none;" data-scan-overlay>
        <div class="lumina-scan-line"></div>
      </div>
      <div class="lumina-placeholder" data-placeholder>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;opacity:0.5;">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
        <p>Position your face in the frame<br>for best results</p>
      </div>
    </div>

    <div class="lumina-controls">
      <button type="button" class="lumina-btn lumina-btn-primary" data-start-btn>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
        Start Camera
      </button>
      <button type="button" class="lumina-btn lumina-btn-primary" style="display:none;" data-capture-btn>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
        </svg>
        Analyze My Skin
      </button>
      <button type="button" class="lumina-btn lumina-btn-secondary" style="display:none;" data-retry-btn>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;">
          <path d="M23 4v6h-6M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
        </svg>
        Try Again
      </button>
    </div>
  </section>

  <section class="lumina-loading" style="display:none;" data-loading-section>
    <div class="lumina-spinner"></div>
    <p>Analyzing your skin...</p>
    <span class="lumina-loading-sub">This takes a few seconds</span>
  </section>

  <section class="lumina-results" style="display:none;" data-results-section>
    <div class="lumina-results-header">
      <h3>Your Skin Analysis</h3>
      <div class="lumina-score" data-score>
        <div class="lumina-score-value">--</div>
        <div class="lumina-score-label">out of 100</div>
      </div>
    </div>

    <div class="lumina-cards-grid">
      <div class="lumina-info-card" data-skin-type>
        <div class="lumina-card-header">
          <div class="lumina-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="8" r="5"/>
              <path d="M20 21a8 8 0 1 0-16 0"/>
            </svg>
          </div>
          <h4>Skin Type</h4>
        </div>
        <div class="lumina-card-content"></div>
      </div>

      <div class="lumina-info-card" data-concerns>
        <div class="lumina-card-header">
          <div class="lumina-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
            </svg>
          </div>
          <h4>Concerns Identified</h4>
        </div>
        <div class="lumina-card-content lumina-tags"></div>
      </div>

      <div class="lumina-info-card full-width" data-ingredients>
        <div class="lumina-card-header">
          <div class="lumina-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>
            </svg>
          </div>
          <h4>Recommended Ingredients</h4>
        </div>
        <div class="lumina-card-content lumina-ingredients-list"></div>
      </div>

      <div class="lumina-routine-card" data-am-routine>
        <div class="lumina-card-header">
          <div class="lumina-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </div>
          <h4>Morning Routine (AM)</h4>
        </div>
        <div class="lumina-card-content lumina-routine-steps"></div>
      </div>

      <div class="lumina-routine-card" data-pm-routine>
        <div class="lumina-card-header">
          <div class="lumina-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </div>
          <h4>Evening Routine (PM)</h4>
        </div>
        <div class="lumina-card-content lumina-routine-steps"></div>
      </div>
    </div>

    <div class="lumina-summary" data-summary>
      <p></p>
    </div>

    <div class="lumina-products" style="display:none;" data-products>
      <h4>Recommended Products For You</h4>
      <div class="lumina-products-grid"></div>
    </div>
  </section>

  {% if block.settings.show_disclaimer %}
  <footer class="lumina-disclaimer">
    <p>This analysis is for cosmetic purposes only and does not constitute medical advice. 
    No images are stored — analysis is performed in real-time and discarded immediately.</p>
  </footer>
  {% endif %}
</div>
